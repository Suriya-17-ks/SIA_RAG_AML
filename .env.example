# SIA-RAG Environment Variables

# ============================================
# LLM PROVIDER CONFIGURATION (REQUIRED)
# ============================================
# Choose one provider: openai, ollama, gemini, groq
LLM_PROVIDER=gemini

# ============================================
# 🆓 FREE OPTION 1: Google Gemini
# ============================================
# FREE TIER: 60 requests/minute
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# 🆓 FREE OPTION 2: Ollama (Local, 100% Private)
# ============================================
# Completely FREE, runs on your computer
# Download from: https://ollama.com
# Then run: ollama pull llama3.2
# 
# To use Ollama, change LLM_PROVIDER to 'ollama' and uncomment:
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2

# ============================================
# 🆓 FREE OPTION 3: Groq (Fastest)
# ============================================
# FREE TIER: 30 requests/minute
# Get your key from: https://console.groq.com
# 
# To use Groq, change LLM_PROVIDER to 'groq' and uncomment:
# LLM_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# 💰 PAID OPTION: OpenAI (Best Quality)
# ============================================
# Get your key from: https://platform.openai.com/api-keys
# 
# To use OpenAI, change LLM_PROVIDER to 'openai' and uncomment:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# EMBEDDING CONFIGURATION (REQUIRED)
# ============================================
# Recommended: Use 'local' for free, offline embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Use OpenAI embeddings (paid)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# WEB SEARCH CONFIGURATION (OPTIONAL)
# ============================================
# Tavily Search API (recommended for web search)
# Get your key from: https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# Generic web search API (if you have one)
# SEARCH_API_KEY=your-search-api-key
# SEARCH_ENDPOINT=https://api.search.com/search

# ============================================
# MODEL OVERRIDES (OPTIONAL)
# ============================================
# Uncomment to override default models (for OpenAI provider only)
# ROUTER_MODEL=gpt-4o-mini
# VERIFIER_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# CHROMADB CONFIGURATION (OPTIONAL)
# ============================================
# CHROMA_PERSIST_DIRECTORY=./chroma_db
# COLLECTION_MICRO=documents_sentences
# COLLECTION_MACRO=documents_sections
